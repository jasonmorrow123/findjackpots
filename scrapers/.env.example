# Copy to .env and fill in your keys

# Yelp Fusion API (free at yelp.com/developers)
YELP_API_KEY=your_yelp_api_key_here

# Twitter/X API v2 (developer.twitter.com)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Google Places API (console.cloud.google.com)
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# OpenAI (for LLM text extraction)
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL database
DATABASE_URL=postgresql://user:password@localhost:5432/jackpotmap

# Reddit API (reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=JackpotMap/1.0

# Optional: Slack webhook for pipeline alerts
SLACK_WEBHOOK_URL=
